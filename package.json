{
  "name": "mechvibes",
  "productName": "Mechvibes",
  "version": "2.4.0-beta.1",
  "description": "Low-latency mechanical keyboard sound engine for Windows.",
  "repository": "https://github.com/omnizs38/mechvibes",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{js,ts}\" \"tools/**/*.js\" \"tests/**/*.js\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"src/**/*.{js,ts,css,html}\" \"tools/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,css,html}\" \"tools/**/*.js\" \"tests/**/*.js\"",
    "build:all": "electron-builder -wml",
    "build:win": "electron-builder -w",
    "build:mac": "electron-builder -m",
    "build:linux": "electron-builder -l",
    "build:win:dir": "electron-builder --win --x64 --dir --publish never",
    "build:clean": "node tools/clean-dist.js",
    "check": "node tools/check-syntax.js",
    "test": "node tests/run.js",
    "benchmark:audio": "node tools/audio-benchmark.js",
    "verify": "npm run check && npm test && npm run typecheck && npm run lint"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "keywords": [],
  "homepage": "https://mechvibes.com",
  "author": {
    "name": "Hai Nguyen",
    "email": "hainguyen.ts13@gmail.com"
  },
  "license": "MIT",
  "build": {
    "appId": "com.electron.mechvibes",
    "artifactName": "Mechvibes-${version}-${arch}.${ext}",
    "files": [
      "src/**/*",
      "package.json",
      "!src/**/*.map"
    ],
    "generateUpdatesFilesForAllChannels": true,
    "publish": [
      {
        "provider": "github",
        "owner": "omnizs38",
        "repo": "mechvibes"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "./build/installer.nsh"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png"
    },
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png"
    },
    "linux": {
      "category": "Utility",
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "snap",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png"
    }
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "adm-zip": "^0.6.0",
    "easy-volume": "^1.1.0",
    "electron-fetch": "^1.9.1",
    "electron-log": "^4.4.8",
    "electron-store": "^6.0.0",
    "electron-updater": "^6.8.8",
    "fs-extra": "^10.1.0",
    "glob": "^9.3.5",
    "howler": "^2.2.4",
    "mime-types": "^2.1.35",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/fs-extra": "^9.0.13",
    "@types/glob": "^8.1.0",
    "@types/howler": "^2.2.12",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "electron": "^43.1.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
