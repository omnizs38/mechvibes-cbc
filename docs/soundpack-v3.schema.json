{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/omnizs38/mechvibes/blob/main/docs/soundpack-v3.schema.json",
  "title": "Mechvibes soundpack v3",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "name"],
  "properties": {
    "version": { "const": 3 },
    "name": { "type": "string", "minLength": 1, "maxLength": 200 },
    "author": { "type": "string", "minLength": 1, "maxLength": 200 },
    "license": { "type": "string", "minLength": 1, "maxLength": 100 },
    "sampleRate": { "type": "integer", "minimum": 22050, "maximum": 192000 },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxVoices": { "type": "integer", "minimum": 1, "maximum": 256, "default": 64 },
        "preload": { "enum": ["all", "priority", "lazy"], "default": "priority" },
        "cacheBudgetMb": { "type": "integer", "minimum": 32, "maximum": 1024, "default": 192 },
        "gain": { "type": "number", "minimum": 0, "maximum": 2, "default": 1 }
      }
    },
    "defaults": { "$ref": "#/$defs/eventLayers" },
    "keys": {
      "type": "object",
      "propertyNames": { "pattern": "^[0-9]+$" },
      "additionalProperties": { "$ref": "#/$defs/eventLayers" }
    },
    "checksums": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
    }
  },
  "anyOf": [
    { "required": ["defaults"] },
    { "required": ["keys"] }
  ],
  "$defs": {
    "eventLayers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "keydown": { "$ref": "#/$defs/layer" },
        "keyup": { "$ref": "#/$defs/layer" }
      },
      "minProperties": 1
    },
    "layer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["samples"],
      "properties": {
        "samples": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              { "$ref": "#/$defs/sample" }
            ]
          }
        },
        "mode": { "enum": ["round-robin", "random"], "default": "round-robin" },
        "gain": { "type": "number", "minimum": 0, "maximum": 2, "default": 1 },
        "pitchVariationCents": { "type": "number", "minimum": 0, "maximum": 100, "default": 0 },
        "priority": { "type": "number", "minimum": 0, "maximum": 10, "default": 5 },
        "envelope": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "attackMs": { "type": "number", "minimum": 0, "maximum": 100, "default": 0 },
            "releaseMs": { "type": "number", "minimum": 0, "maximum": 2000, "default": 12 }
          }
        }
      }
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file"],
      "properties": {
        "file": { "type": "string", "minLength": 1 },
        "gain": { "type": "number", "minimum": 0, "maximum": 2, "default": 1 },
        "pitch": { "type": "number", "minimum": -1200, "maximum": 1200, "default": 0 },
        "weight": { "type": "number", "exclusiveMinimum": 0, "maximum": 100, "default": 1 }
      }
    }
  }
}
